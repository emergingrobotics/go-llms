// TestAPIClientTool_BasicGET tests basic GET request functionality
func TestAPIClientTool_BasicGET(t *testing.T) {
	// Create test server
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if r.Method != http.MethodGet {
			t.Errorf("Expected GET, got %s", r.Method)
		}

		// Return simple JSON response
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]interface{}{
			"message": "Hello from API",
			"path":    r.URL.Path,
			"query":   r.URL.Query().Get("name"),
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	// Test simple GET request
	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/greeting",
		"method":   "GET",
		"query_params": map[string]string{
			"name": "LLM",
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute failed: %v", err)
	}

	// Check result structure
	resultMap, ok := result.(map[string]interface{})
	if !ok {
		t.Fatalf("Expected map result, got %T", result)
	}

	// Verify success
	if resultMap["success"] != true {
		t.Errorf("Expected success=true, got %v", resultMap["success"])
	}

	// Check response data
	data, ok := resultMap["data"].(map[string]interface{})
	if !ok {
		t.Fatalf("Expected data map, got %T", resultMap["data"])
	}

	if data["message"] != "Hello from API" {
		t.Errorf("Expected message 'Hello from API', got %v", data["message"])
	}

	if data["query"] != "LLM" {
		t.Errorf("Expected query param 'LLM', got %v", data["query"])
	}
}

// TestAPIClientTool_POST tests POST request with JSON body
func TestAPIClientTool_POST(t *testing.T) {
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if r.Method != http.MethodPost {
			t.Errorf("Expected POST, got %s", r.Method)
		}

		// Parse request body
		var body map[string]interface{}
		if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
			http.Error(w, "Invalid JSON", http.StatusBadRequest)
			return
		}

		// Echo back the data
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusCreated)
		json.NewEncoder(w).Encode(map[string]interface{}{
			"id":      123,
			"created": true,
			"data":    body,
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/items",
		"method":   "POST",
		"body": map[string]interface{}{
			"name":        "Test Item",
			"description": "Created by LLM",
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute failed: %v", err)
	}

	resultMap := result.(map[string]interface{})

	// Check status code
	if resultMap["status_code"] != float64(201) {
		t.Errorf("Expected status code 201, got %v", resultMap["status_code"])
	}

	// Check response data
	data := resultMap["data"].(map[string]interface{})
	if data["created"] != true {
		t.Errorf("Expected created=true")
	}

	// Verify echoed data
	echoedData := data["data"].(map[string]interface{})
	if echoedData["name"] != "Test Item" {
		t.Errorf("Expected name 'Test Item', got %v", echoedData["name"])
	}
}

// TestAPIClientTool_APIKeyAuth tests API key authentication
func TestAPIClientTool_APIKeyAuth(t *testing.T) {
	expectedAPIKey := "test-api-key-123"

	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Check API key in header
		apiKey := r.Header.Get("X-API-Key")
		if apiKey != expectedAPIKey {
			w.WriteHeader(http.StatusUnauthorized)
			json.NewEncoder(w).Encode(map[string]string{
				"error": "Invalid API key",
			})
			return
		}

		// Success response
		json.NewEncoder(w).Encode(map[string]interface{}{
			"authenticated": true,
			"user":          "api-user",
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	// Test with API key
	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/protected",
		"method":   "GET",
		"auth": map[string]interface{}{
			"type":         "api_key",
			"api_key":      expectedAPIKey,
			"key_location": "header",
			"key_name":     "X-API-Key",
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute with API key failed: %v", err)
	}

	resultMap := result.(map[string]interface{})
	data := resultMap["data"].(map[string]interface{})

	if data["authenticated"] != true {
		t.Errorf("Expected authenticated=true")
	}

	// Test without API key (should fail)
	params["auth"] = nil
	result, err = tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute without API key failed: %v", err)
	}

	resultMap = result.(map[string]interface{})
	if resultMap["success"] != false {
		t.Errorf("Expected request without API key to fail")
	}

	if resultMap["status_code"] != float64(401) {
		t.Errorf("Expected 401 status code, got %v", resultMap["status_code"])
	}
}

// TestAPIClientTool_BearerAuth tests Bearer token authentication
func TestAPIClientTool_BearerAuth(t *testing.T) {
	expectedToken := "bearer-token-abc123"

	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Check Bearer token
		auth := r.Header.Get("Authorization")
		if !strings.HasPrefix(auth, "Bearer ") || auth[7:] != expectedToken {
			w.WriteHeader(http.StatusUnauthorized)
			json.NewEncoder(w).Encode(map[string]string{
				"error": "Invalid bearer token",
			})
			return
		}

		json.NewEncoder(w).Encode(map[string]interface{}{
			"user_id": "12345",
			"scope":   "read write",
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/user/profile",
		"method":   "GET",
		"auth": map[string]interface{}{
			"type":  "bearer",
			"token": expectedToken,
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute with bearer token failed: %v", err)
	}

	resultMap := result.(map[string]interface{})
	if resultMap["success"] != true {
		t.Errorf("Expected successful request with bearer token")
	}

	data := resultMap["data"].(map[string]interface{})
	if data["user_id"] != "12345" {
		t.Errorf("Expected user_id '12345', got %v", data["user_id"])
	}
}

// TestAPIClientTool_ErrorHandling tests error response handling
func TestAPIClientTool_ErrorHandling(t *testing.T) {
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		switch r.URL.Path {
		case "/not-found":
			w.WriteHeader(http.StatusNotFound)
			json.NewEncoder(w).Encode(map[string]string{
				"error": "Resource not found",
				"code":  "RESOURCE_NOT_FOUND",
			})
		case "/server-error":
			w.WriteHeader(http.StatusInternalServerError)
			json.NewEncoder(w).Encode(map[string]string{
				"error": "Internal server error",
			})
		case "/bad-request":
			w.WriteHeader(http.StatusBadRequest)
			json.NewEncoder(w).Encode(map[string]interface{}{
				"error": "Validation failed",
				"errors": map[string]string{
					"email": "Invalid email format",
					"age":   "Must be positive",
				},
			})
		}
	}))
	defer server.Close()

	// Add test cases for error handling here if needed
	t.Skip("Error handling test implementation needed")
}

// TestAPIClientTool_GraphQLWithAuthFromState tests GraphQL authentication detection from state
func TestAPIClientTool_GraphQLWithAuthFromState(t *testing.T) {
	// Create test server that checks for authorization
	authToken := "ghp_test123456"
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Check authorization header
		auth := r.Header.Get("Authorization")
		expectedAuth := "Bearer " + authToken
		
		if auth != expectedAuth {
			w.WriteHeader(http.StatusUnauthorized)
			json.NewEncoder(w).Encode(map[string]interface{}{
				"errors": []map[string]interface{}{
					{
						"message": "Authentication required",
					},
				},
			})
			return
		}

		// Decode GraphQL request
		var req map[string]interface{}
		if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
			t.Fatalf("Failed to decode request: %v", err)
		}

		// Check if it's introspection
		query, _ := req["query"].(string)
		if strings.Contains(query, "__schema") {
			// Return introspection response
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{
				"data": map[string]interface{}{
					"__schema": map[string]interface{}{
						"queryType": map[string]interface{}{
							"name": "Query",
						},
						"types": []map[string]interface{}{
							{
								"name":        "User",
								"kind":        "OBJECT",
								"description": "User type",
							},
						},
					},
				},
			})
		} else {
			// Return query response
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{
				"data": map[string]interface{}{
					"viewer": map[string]interface{}{
						"login": "testuser",
						"name":  "Test User",
					},
				},
			})
		}
	}))
	defer server.Close()

	tool := NewAPIClientTool()

	tests := []struct {
		name        string
		stateValues map[string]interface{}
		params      map[string]interface{}
		expectAuth  bool
		expectError bool
	}{
		{
			name: "GitHub GraphQL with github_token in state",
			stateValues: map[string]interface{}{
				"github_token": authToken,
			},
			params: map[string]interface{}{
				"base_url":      server.URL,
				"endpoint":      "/graphql",
				"graphql_query": "query { viewer { login name } }",
			},
			expectAuth:  true,
			expectError: false,
		},
		{
			name: "GitHub GraphQL with github_api_key in state",
			stateValues: map[string]interface{}{
				"github_api_key": authToken,
			},
			params: map[string]interface{}{
				"base_url":      strings.Replace(server.URL, "127.0.0.1", "api.github.com", 1), // Simulate GitHub URL
				"endpoint":      "/graphql",
				"graphql_query": "query { viewer { login name } }",
			},
			expectAuth:  true,
			expectError: false,
		},
		{
			name:        "GitHub GraphQL without auth in state",
			stateValues: map[string]interface{}{},
			params: map[string]interface{}{
				"base_url":      server.URL,
				"endpoint":      "/graphql",
				"graphql_query": "query { viewer { login name } }",
			},
			expectAuth:  false,
			expectError: true, // Should get 401
		},
		{
			name: "GraphQL discovery with auth from state",
			stateValues: map[string]interface{}{
				"github_token": authToken,
			},
			params: map[string]interface{}{
				"base_url":         strings.Replace(server.URL, "127.0.0.1", "api.github.com", 1),
				"endpoint":         "/graphql",
				"discover_graphql": true,
			},
			expectAuth:  true,
			expectError: false,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			// Create state with test values
			state := domain.NewState()
			for k, v := range tt.stateValues {
				state.Set(k, v)
			}

			// Create tool context
			ctx := &domain.ToolContext{
				Context:   context.Background(),
				State:     domain.NewStateReader(state),
				RunID:     "test-run",
				StartTime: time.Now(),
			}

			// Execute tool
			result, err := tool.Execute(ctx, tt.params)

			if tt.expectError {
				if err == nil {
					// Check if error is in the result
					if resultMap, ok := result.(map[string]interface{}); ok {
						if success, ok := resultMap["success"].(bool); ok && success {
							t.Error("Expected error but got success")
						}
					}
				}
			} else {
				if err != nil {
					t.Errorf("Unexpected error: %v", err)
				} else if resultMap, ok := result.(map[string]interface{}); ok {
					if success, ok := resultMap["success"].(bool); !ok || !success {
						t.Errorf("Expected success but got: %v", result)
					}
				}
			}
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	testCases := []struct {
		name           string
		endpoint       string
		expectedStatus float64
		checkError     func(t *testing.T, result map[string]interface{})
	}{
		{
			name:           "404 Not Found",
			endpoint:       "/not-found",
			expectedStatus: 404,
			checkError: func(t *testing.T, result map[string]interface{}) {
				errorInfo := result["error_details"].(map[string]interface{})
				if errorInfo["code"] != "RESOURCE_NOT_FOUND" {
					t.Errorf("Expected error code RESOURCE_NOT_FOUND")
				}
			},
		},
		{
			name:           "500 Server Error",
			endpoint:       "/server-error",
			expectedStatus: 500,
			checkError: func(t *testing.T, result map[string]interface{}) {
				guidance := result["error_guidance"].(string)
				if !strings.Contains(guidance, "server-side") {
					t.Errorf("Expected server error guidance")
				}
			},
		},
		{
			name:           "400 Bad Request",
			endpoint:       "/bad-request",
			expectedStatus: 400,
			checkError: func(t *testing.T, result map[string]interface{}) {
				errorInfo := result["error_details"].(map[string]interface{})
				errors := errorInfo["errors"].(map[string]interface{})
				if errors["email"] != "Invalid email format" {
					t.Errorf("Expected validation error for email")
				}
			},
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			params := map[string]interface{}{
				"base_url": server.URL,
				"endpoint": tc.endpoint,
				"method":   "GET",
			}

			result, err := tool.Execute(ctx, params)
			if err != nil {
				t.Fatalf("Execute failed: %v", err)
			}

			resultMap := result.(map[string]interface{})

			// Should not be successful
			if resultMap["success"] != false {
				t.Errorf("Expected success=false for error response")
			}

			// Check status code
			if resultMap["status_code"] != tc.expectedStatus {
				t.Errorf("Expected status %v, got %v", tc.expectedStatus, resultMap["status_code"])
			}

			// Run specific error checks
			tc.checkError(t, resultMap)
		})
	}
}

// TestAPIClientTool_MCPExport tests that the API Client Tool exports correctly to MCP format
func TestAPIClientTool_MCPExport(t *testing.T) {
	// Get the tool from registry
	tool, exists := tools.Tools.Get("api_client")
	if !exists {
		t.Fatal("api_client tool not found in registry")
	}

	// Export to MCP format
	mcpDef, err := tools.Tools.ExportToMCP("api_client")
	if err != nil {
		t.Fatalf("Failed to export api_client to MCP format: %v", err)
	}

	// Verify we got the tool (to satisfy the compiler about unused variable)
	_ = tool

	// Validate basic fields
	if mcpDef.Name != "api_client" {
		t.Errorf("Expected name 'api_client', got %s", mcpDef.Name)
	}

	if mcpDef.Description == "" {
		t.Error("Description should not be empty")
	}

	// Validate input schema
	if mcpDef.InputSchema == nil {
		t.Fatal("InputSchema should not be nil")
	}

	// Check that input schema has required properties
	inputSchemaJSON, err := json.Marshal(mcpDef.InputSchema)
	if err != nil {
		t.Fatalf("Failed to marshal input schema: %v", err)
	}

	var inputSchema map[string]interface{}
	if err := json.Unmarshal(inputSchemaJSON, &inputSchema); err != nil {
		t.Fatalf("Failed to unmarshal input schema: %v", err)
	}

	// Check for required properties
	props, ok := inputSchema["properties"].(map[string]interface{})
	if !ok {
		t.Fatal("Input schema should have properties")
	}

	requiredProps := []string{"base_url", "endpoint"}
	for _, prop := range requiredProps {
		if _, exists := props[prop]; !exists {
			t.Errorf("Required property '%s' not found in input schema", prop)
		}
	}

	// Check optional properties
	optionalProps := []string{"method", "headers", "body", "auth", "query_params", "path_params", "timeout"}
	for _, prop := range optionalProps {
		if _, exists := props[prop]; !exists {
			t.Errorf("Optional property '%s' not found in input schema", prop)
		}
	}

	// Validate annotations contain expected metadata
	if mcpDef.Annotations == nil {
		t.Fatal("Annotations should not be nil")
	}

	// Check for expected annotation fields
	if _, hasExamples := mcpDef.Annotations["examples"]; !hasExamples {
		t.Error("Should have examples in annotations")
	}

	if _, hasConstraints := mcpDef.Annotations["constraints"]; !hasConstraints {
		t.Error("Should have constraints in annotations")
	}

	if _, hasErrorGuidance := mcpDef.Annotations["error_guidance"]; !hasErrorGuidance {
		t.Error("Should have error guidance in annotations")
	}

	// Check behavioral hints
	if behavioralHints, ok := mcpDef.Annotations["behavioralHints"].(map[string]interface{}); ok {
		if deterministic, exists := behavioralHints["deterministic"]; exists {
			if det, ok := deterministic.(bool); ok && det {
				t.Error("API client should be marked as non-deterministic")
			}
		}
	}

	// Log the MCP definition for inspection
	mcpJSON, err := json.MarshalIndent(mcpDef, "", "  ")
	if err != nil {
		t.Fatalf("Failed to marshal MCP definition: %v", err)
	}
	t.Logf("MCP Definition:\n%s", string(mcpJSON))
}

// TestAPIClientTool_MCPCatalog tests that the API Client Tool is included in the MCP catalog export
func TestAPIClientTool_MCPCatalog(t *testing.T) {
	// Export all tools to MCP catalog
	catalog, err := tools.Tools.ExportAllToMCP()
	if err != nil {
		t.Fatalf("Failed to export MCP catalog: %v", err)
	}

	// Find api_client in the catalog
	found := false
	for _, tool := range catalog.Tools {
		if tool.Name == "api_client" {
			found = true

			// Validate it's in the web category through annotations
			if tool.Annotations != nil {
				if category, hasCategory := tool.Annotations["category"].(string); hasCategory {
					if category != "web" {
						t.Errorf("Expected category 'web', got %s", category)
					}
				}

				// Check tags
				if tags, hasTags := tool.Annotations["tags"].([]interface{}); hasTags {
					expectedTags := []string{"api", "rest", "http", "integration", "client"}
					tagMap := make(map[string]bool)
					for _, tag := range tags {
						if tagStr, ok := tag.(string); ok {
							tagMap[tagStr] = true
						}
					}

					for _, tag := range expectedTags {
						if !tagMap[tag] {
							t.Errorf("Expected tag '%s' not found", tag)
						}
					}
				}
			}

			break
		}
	}

	if !found {
		t.Error("api_client tool not found in MCP catalog")
	}
}

// TestAPIClientTool_PathParameters tests path parameter substitution
func TestAPIClientTool_PathParameters(t *testing.T) {
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Extract path segments
		parts := strings.Split(r.URL.Path, "/")
		if len(parts) != 4 || parts[1] != "users" || parts[3] != "posts" {
			w.WriteHeader(http.StatusNotFound)
			return
		}

		userID := parts[2]
		json.NewEncoder(w).Encode(map[string]interface{}{
			"user_id": userID,
			"posts":   []string{"post1", "post2"},
		})
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/users/{user_id}/posts",
		"method":   "GET",
		"path_params": map[string]string{
			"user_id": "alice123",
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute failed: %v", err)
	}

	resultMap := result.(map[string]interface{})
	data := resultMap["data"].(map[string]interface{})

	if data["user_id"] != "alice123" {
		t.Errorf("Expected user_id 'alice123', got %v", data["user_id"])
	}
}

// TestAPIClientTool_Headers tests custom header handling
func TestAPIClientTool_Headers(t *testing.T) {
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Echo back some headers
		response := map[string]interface{}{
			"headers": map[string]string{
				"user-agent":    r.Header.Get("User-Agent"),
				"accept":        r.Header.Get("Accept"),
				"custom-header": r.Header.Get("X-Custom-Header"),
			},
		}

		json.NewEncoder(w).Encode(response)
	}))
	defer server.Close()

	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	params := map[string]interface{}{
		"base_url": server.URL,
		"endpoint": "/echo",
		"method":   "GET",
		"headers": map[string]string{
			"Accept":          "application/json",
			"X-Custom-Header": "custom-value",
		},
	}

	result, err := tool.Execute(ctx, params)
	if err != nil {
		t.Fatalf("Execute failed: %v", err)
	}

	resultMap := result.(map[string]interface{})
	data := resultMap["data"].(map[string]interface{})
	headers := data["headers"].(map[string]interface{})

	if headers["custom-header"] != "custom-value" {
		t.Errorf("Expected custom header 'custom-value', got %v", headers["custom-header"])
	}

	if headers["accept"] != "application/json" {
		t.Errorf("Expected Accept header 'application/json', got %v", headers["accept"])
	}
}

// TestAPIClientTool_Validation tests parameter validation
func TestAPIClientTool_Validation(t *testing.T) {
	tool := NewAPIClientTool()
	state := domain.NewState()
	ctx := &domain.ToolContext{
		Context:   context.Background(),
		State:     domain.NewStateReader(state),
		RunID:     "test-run",
		StartTime: time.Now(),
		Agent: domain.AgentInfo{
			ID:   "test-agent",
			Name: "Test Agent",
			Type: domain.AgentTypeCustom,
		},
	}

	testCases := []struct {
		name        string
		params      map[string]interface{}
		expectError bool
		errorMsg    string
	}{
		{
			name:        "Missing base_url",
			params:      map[string]interface{}{"endpoint": "/test"},
			expectError: true,
			errorMsg:    "base_url is required",
		},
		{
			name:        "Invalid URL",
			params:      map[string]interface{}{"base_url": "not-a-url", "endpoint": "/test"},
			expectError: true,
			errorMsg:    "invalid base_url",
		},
		{
			name:        "Missing endpoint",
			params:      map[string]interface{}{"base_url": "https://api.example.com"},
			expectError: true,
			errorMsg:    "endpoint is required",
		},
		{
			name:        "Invalid method",
			params:      map[string]interface{}{"base_url": "https://api.example.com", "endpoint": "/test", "method": "INVALID"},
			expectError: true,
			errorMsg:    "invalid method",
		},
		{
			name: "Invalid auth type",
			params: map[string]interface{}{
				"base_url": "https://api.example.com",
				"endpoint": "/test",
				"auth": map[string]interface{}{
					"type": "invalid-auth",
				},
			},
			expectError: true,
			errorMsg:    "unsupported auth type",
		},
		{
			name: "Valid basic params",
			params: map[string]interface{}{
				"base_url": "https://api.example.com",
				"endpoint": "/test",
			},
			expectError: false,
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			_, err := tool.Execute(ctx, tc.params)
			if tc.expectError {
				if err == nil {
					t.Errorf("Expected error containing '%s', got nil", tc.errorMsg)
				} else if !strings.Contains(err.Error(), tc.errorMsg) {
					t.Errorf("Expected error containing '%s', got: %v", tc.errorMsg, err)
				}
			} else {
				// For valid params, we expect a connection error (since it's not a real server)
				// but not a validation error
				if err != nil && strings.Contains(err.Error(), "validation") {
					t.Errorf("Unexpected validation error: %v", err)
				}
			}
		})
	}
}
