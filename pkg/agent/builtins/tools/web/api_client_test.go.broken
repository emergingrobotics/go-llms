// ABOUTME: Tests for API Client Tool focusing on LLM-friendly REST API interactions
// ABOUTME: Validates basic operations, auth, error handling, and API discovery

package web

import (
	"context"
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"strings"
	"testing"
	"time"

	"github.com/lexlapax/go-llms/pkg/agent/builtins/tools"
	"github.com/lexlapax/go-llms/pkg/agent/domain"
